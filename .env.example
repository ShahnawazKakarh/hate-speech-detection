# Copy to .env and fill in values you want to use.
# .env is git-ignored; .env.example is committed.

# Hugging Face Hub token (optional, raises rate limits for model downloads)
HF_TOKEN=

# Gemini API key (only needed if calling Google's native SDK directly;
# for v0.2.1 we use OpenRouter as the unified provider)
GEMINI_API_KEY=

# OpenRouter API key — unified endpoint for Gemini / Claude / Llama / DeepSeek
# Sign up at https://openrouter.ai and grab a key at https://openrouter.ai/keys
# Also set a monthly spend cap at https://openrouter.ai/settings/credits
OPENROUTER_API_KEY=

# Optional: require explicit confirmation before any run whose pre-flight cost
# estimate exceeds the config's confirm_over_usd. Uncomment or export ad-hoc:
#     HSD_CONFIRM_COST=1 python -m hsd.train --config <config>

# Weights & Biases (optional, for experiment tracking)
WANDB_API_KEY=
WANDB_ENTITY=qapulsebysk
WANDB_PROJECT=hate-speech-detection
